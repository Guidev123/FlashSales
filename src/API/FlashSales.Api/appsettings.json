{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": ""
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "FlashSales.Api"
    }
  },
  "ConnectionStrings": {
    "Postgres": "",
    "Redis": ""
  },
  "PermissionsCache": {
    "CacheExpirationInSeconds": 900
  },
  "BlobStorage": {
    "ConnectionString": "",
    "ContainerName": ""
  },
  "Authentication": {
    "Authority": "",
    "Audience": "",
    "RequireHttpsMetadata": true,
    "MetadataAddress": ""
  },
  "WebAppEndpoints": "",
  "Keycloak": {
    "AuthorizationUrl": "",
    "TokenUrl": "",
    "SwaggerClientId": ""
  },
  "AllowedHosts": "*"
}